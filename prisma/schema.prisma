generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  username      String?   @unique
  bio           String?
  isPublic      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Orbs (moeda interna)
  orbs             Int       @default(500)  @map("prediction_coins")
  totalOrbsEarned  Int       @default(0)   @map("total_coins_earned")
  totalOrbsLost    Int       @default(0)   @map("total_coins_lost")

  // Streaks
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityAt   DateTime?

  // Nível e XP
  level            Int       @default(1)
  xp               Int       @default(0)

  // Location (for geo rankings)
  city    String?
  state   String?
  country String? @default("BR")

  // Email verification
  emailVerificationToken   String?
  emailVerificationExpires DateTime?

  // Notification preferences
  notifEmailDigest         Boolean   @default(true)
  notifExpiringPredictions Boolean   @default(true)

  accounts           Account[]
  sessions           Session[]
  predictions        Prediction[]
  badges             UserBadge[]
  orbTransactions    OrbTransaction[]
  bolaosCreated      Bolao[]             @relation("BolaoCreator")
  bolaoMembers       BolaoMember[]
  bolaoPayments      BolaoPayment[]
  paymentsConfirmed  BolaoPayment[]      @relation("PaymentConfirmer")
  gruposCreated      Grupo[]             @relation("GrupoCreator")
  grupoMembers       GrupoMember[]
  mercadosCriados    GrupoMercado[]      @relation("MercadoCreator")
  mercadosResolvidos GrupoMercado[]      @relation("MercadoResolver")
  notifications      Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Prediction {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?     @db.Text
  probability Int
  category    Category
  expiresAt   DateTime
  resolvedAt  DateTime?
  resolution  Resolution?
  isPublic    Boolean     @default(false)
  shareToken  String?     @unique @default(cuid())
  evidence    String?     @db.Text
  tags        String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Resolution metadata
  resolutionType ResolutionType?

  // Coins allocated to this prediction
  coinsAllocated Int?
  coinsResult    Int?

  // Market matching
  polymarketSlug        String?
  polymarketQuestion    String?
  polymarketProbability Float?
  polymarketUrl         String?
  polymarketUpdatedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("predictions")
}

enum Category {
  TECHNOLOGY
  ECONOMY
  MARKETS
  STARTUPS
  GEOPOLITICS
  SCIENCE
  SPORTS
  CULTURE
  OTHER
}

enum Resolution {
  CORRECT
  INCORRECT
  PARTIAL
  CANCELLED
}

enum ResolutionType {
  MANUAL
  AUTOMATIC
}

model UserBadge {
  id       String      @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime    @default(now())
  source   BadgeSource @default(AUTOMATIC)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("user_badges")
}

enum BadgeSource {
  AUTOMATIC
  PURCHASED
}

model OrbTransaction {
  id           String    @id @default(cuid())
  userId       String
  amount       Int
  reason       OrbReason
  description  String?
  predictionId String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orb_transactions")
}

enum OrbReason {
  SIGNUP_BONUS
  PREDICTION_CORRECT
  PREDICTION_EXACT
  PREDICTION_INCORRECT
  STREAK_BONUS
  STREAK_MILESTONE
  LEVEL_UP
  FIRST_PREDICTION
  BOLAO_WIN
  BOLAO_TOP3
  DAILY_LOGIN
  SHARE_PREDICTION
  BADGE_PURCHASE
  THEME_PURCHASE
  BOOST_PURCHASE
  BADGE_EARNED
}

model RankingSnapshot {
  id        String   @id @default(cuid())
  userId    String
  rankType  String
  period    String
  score     Float
  rank      Int
  updatedAt DateTime @default(now())

  @@unique([userId, rankType, period])
  @@map("ranking_snapshots")
}

// ─── BOLÃO TRADICIONAL ───────────────────────────────────────────────────────

enum BolaoRole {
  ADMIN
  MEMBER
}

enum BolaoType {
  SPORTS
  CUSTOM
}

enum JogoStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

enum PrizeStatus {
  PENDING
  FINISHED
  PAID
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model Bolao {
  id          String    @id @default(cuid())
  name        String
  description String?
  slug        String    @unique
  inviteCode  String    @unique @default(cuid())
  creatorId   String
  type        BolaoType @default(SPORTS)
  coverEmoji  String    @default("🏆")
  isPublic    Boolean   @default(false)
  maxMembers  Int?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Prize
  hasPrize          Boolean     @default(false)
  prizeDescription  String?
  prizePixKey       String?
  prizePool         String?
  prizeDistribution String?
  prizeStatus       PrizeStatus @default(PENDING)
  prizeWinnerId     String?

  // Scoring
  pointsExact  Int @default(10)
  pointsResult Int @default(5)

  creator  User          @relation("BolaoCreator", fields: [creatorId], references: [id])
  members  BolaoMember[]
  jogos    BolaoJogo[]
  payments BolaoPayment[]

  @@map("bolaos")
}

model BolaoMember {
  id       String    @id @default(cuid())
  bolaoId  String
  userId   String
  role     BolaoRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  nickname String?

  bolao    Bolao          @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  palpites BolaoPalpite[]

  @@unique([bolaoId, userId])
  @@map("bolao_members")
}

model BolaoJogo {
  id           String     @id @default(cuid())
  bolaoId      String
  name         String
  description  String?
  homeTeam     String?
  awayTeam     String?
  options      String?    // JSON array for CUSTOM type
  scheduledAt  DateTime
  phase        String?
  status       JogoStatus @default(SCHEDULED)
  resultHome   Int?
  resultAway   Int?
  resultOption String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime   @default(now())

  bolao    Bolao          @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  palpites BolaoPalpite[]

  @@map("bolao_jogos")
}

model BolaoPalpite {
  id            String   @id @default(cuid())
  jogoId        String
  memberId      String
  palpiteHome   Int?
  palpiteAway   Int?
  palpiteOption String?
  pontos        Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jogo   BolaoJogo   @relation(fields: [jogoId], references: [id], onDelete: Cascade)
  member BolaoMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([jogoId, memberId])
  @@map("bolao_palpites")
}

model BolaoPayment {
  id          String        @id @default(cuid())
  bolaoId     String
  userId      String
  amount      Float
  status      PaymentStatus @default(PENDING)
  confirmedBy String?
  confirmedAt DateTime?
  note        String?
  createdAt   DateTime      @default(now())

  bolao     Bolao @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id])
  confirmer User? @relation("PaymentConfirmer", fields: [confirmedBy], references: [id])

  @@unique([bolaoId, userId])
  @@map("bolao_payments")
}

// ─── GRUPOS (MERCADOS DE PROBABILIDADE) ─────────────────────────────────────

enum GrupoRole {
  ADMIN
  MEMBER
}

enum GrupoResolution {
  SIM
  NAO
  CANCELADO
}

model Grupo {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  inviteCode  String   @unique @default(cuid())
  creatorId   String
  coverEmoji  String   @default("🔮")
  isPublic    Boolean  @default(false)
  maxMembers  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator  User           @relation("GrupoCreator", fields: [creatorId], references: [id])
  members  GrupoMember[]
  mercados GrupoMercado[]

  @@map("grupos")
}

model GrupoMember {
  id       String    @id @default(cuid())
  grupoId  String
  userId   String
  role     GrupoRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  grupo  Grupo              @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  user   User               @relation(fields: [userId], references: [id])
  votos  GrupoMercadoVoto[]

  @@unique([grupoId, userId])
  @@map("grupo_members")
}

model GrupoMercado {
  id           String           @id @default(cuid())
  grupoId      String
  creatorId    String
  question     String
  description  String?
  category     Category?
  expiresAt    DateTime
  resolvedAt   DateTime?
  resolution   GrupoResolution?
  resolvedById String?
  isOpen       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  grupo      Grupo              @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  creator    User               @relation("MercadoCreator", fields: [creatorId], references: [id])
  resolvedBy User?              @relation("MercadoResolver", fields: [resolvedById], references: [id])
  votos      GrupoMercadoVoto[]

  @@map("grupo_mercados")
}

model GrupoMercadoVoto {
  id          String   @id @default(cuid())
  mercadoId   String
  memberId    String
  probability Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mercado GrupoMercado @relation(fields: [mercadoId], references: [id], onDelete: Cascade)
  member  GrupoMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([mercadoId, memberId])
  @@map("grupo_mercado_votos")
}

// ─── NOTIFICATIONS & SOCIAL ──────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SocialPost {
  id              String   @id @default(cuid())
  date            String
  marketTitle     String
  marketSlug      String
  probability     Int
  unsplashUrl     String
  unsplashAuthor  String?
  ogImageUrl      String
  caption         String   @db.Text
  instagramPostId String?
  twitterPostId   String?
  status          String   @default("pending")
  error           String?
  createdAt       DateTime @default(now())
  platform      String   @default("instagram")
  scheduledTime String?
  imageFormat   String   @default("square")

  @@map("social_posts")
}

model CustomMarket {
  id          String    @id @default(cuid())
  question    String
  probability Int       // 1-99, probabilidade actual estimada
  category    Category
  endDate     DateTime?
  url         String?   // link externo opcional
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("custom_markets")
}
