generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  username      String?   @unique
  bio           String?
  isPublic      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Gamification
  predictionCoins  Int       @default(500)
  totalCoinsEarned Int       @default(0)
  totalCoinsLost   Int       @default(0)
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityAt   DateTime?
  level            Int       @default(1)
  xp               Int       @default(0)

  // Location (for geo rankings)
  city    String?
  state   String?
  country String? @default("BR")

  // Email verification
  emailVerificationToken   String?
  emailVerificationExpires DateTime?

  // Notification preferences
  notifEmailDigest         Boolean   @default(true)
  notifExpiringPredictions Boolean   @default(true)

  accounts           Account[]
  sessions           Session[]
  predictions        Prediction[]
  badges             UserBadge[]
  coinTransactions   CoinTransaction[]
  bolaosCreated      Bolao[]             @relation("BolaoCreator")
  bolaoMembers       BolaoMember[]
  bolaoPredicoes     BolaoPredicao[]
  bolaoPayments      BolaoPayment[]
  paymentsConfirmed  BolaoPayment[]      @relation("PaymentConfirmer")
  mercadosCriados    GrupoMercado[]      @relation("MercadoCreator")
  mercadosResolvidos GrupoMercado[]      @relation("MercadoResolver")
  mercadoVotos       GrupoMercadoVoto[]
  notifications      Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Prediction {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?     @db.Text
  probability Int
  category    Category
  expiresAt   DateTime
  resolvedAt  DateTime?
  resolution  Resolution?
  isPublic    Boolean     @default(false)
  shareToken  String?     @unique @default(cuid())
  evidence    String?     @db.Text
  tags        String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Resolution metadata
  resolutionType ResolutionType?

  // Coins allocated to this prediction
  coinsAllocated Int?
  coinsResult    Int?

  // Market matching
  polymarketSlug        String?
  polymarketQuestion    String?
  polymarketProbability Float?
  polymarketUrl         String?
  polymarketUpdatedAt   DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bolaoPredicoes BolaoPredicao[]

  @@map("predictions")
}

enum Category {
  TECHNOLOGY
  ECONOMY
  MARKETS
  STARTUPS
  GEOPOLITICS
  SCIENCE
  SPORTS
  CULTURE
  OTHER
}

enum Resolution {
  CORRECT
  INCORRECT
  PARTIAL
  CANCELLED
}

enum ResolutionType {
  MANUAL
  AUTOMATIC
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("user_badges")
}

model CoinTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  reason       String
  predictionId String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coin_transactions")
}

model RankingSnapshot {
  id        String   @id @default(cuid())
  userId    String
  rankType  String
  period    String
  score     Float
  rank      Int
  updatedAt DateTime @default(now())

  @@unique([userId, rankType, period])
  @@map("ranking_snapshots")
}

enum BolaoRole {
  ADMIN
  MEMBER
}

model Bolao {
  id          String    @id @default(cuid())
  name        String
  description String?
  slug        String    @unique
  inviteCode  String    @unique @default(cuid())
  creatorId   String
  isPublic    Boolean   @default(false)
  coverEmoji  String    @default("🔮")
  category    Category?
  endsAt      DateTime?
  maxMembers  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator    User            @relation("BolaoCreator", fields: [creatorId], references: [id])
  members    BolaoMember[]
  predicoes  BolaoPredicao[]
  payments   BolaoPayment[]
  mercados   GrupoMercado[]

  @@map("bolaos")
}

model BolaoMember {
  id       String    @id @default(cuid())
  bolaoId  String
  userId   String
  role     BolaoRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  nickname String?

  bolao Bolao @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bolaoId, userId])
  @@map("bolao_members")
}

model BolaoPredicao {
  id           String   @id @default(cuid())
  bolaoId      String
  predictionId String
  addedById    String
  createdAt    DateTime @default(now())

  bolao      Bolao      @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  prediction Prediction @relation(fields: [predictionId], references: [id])
  addedBy    User       @relation(fields: [addedById], references: [id])

  @@unique([bolaoId, predictionId])
  @@map("bolao_predicoes")
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model BolaoPayment {
  id          String        @id @default(cuid())
  bolaoId     String
  userId      String
  amount      Float
  status      PaymentStatus @default(PENDING)
  confirmedBy String?
  confirmedAt DateTime?
  note        String?
  createdAt   DateTime      @default(now())

  bolao     Bolao @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id])
  confirmer User? @relation("PaymentConfirmer", fields: [confirmedBy], references: [id])

  @@unique([bolaoId, userId])
  @@map("bolao_payments")
}

enum GrupoResolution {
  SIM
  NAO
  CANCELADO
}

model GrupoMercado {
  id           String          @id @default(cuid())
  bolaoId      String
  creatorId    String
  question     String
  description  String?
  category     Category?
  expiresAt    DateTime
  resolvedAt   DateTime?
  resolution   GrupoResolution?
  resolvedById String?
  isOpen       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  bolao      Bolao              @relation(fields: [bolaoId], references: [id], onDelete: Cascade)
  creator    User               @relation("MercadoCreator", fields: [creatorId], references: [id])
  resolvedBy User?              @relation("MercadoResolver", fields: [resolvedById], references: [id])
  votos      GrupoMercadoVoto[]

  @@map("grupo_mercados")
}

model GrupoMercadoVoto {
  id          String   @id @default(cuid())
  mercadoId   String
  userId      String
  probability Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mercado GrupoMercado @relation(fields: [mercadoId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])

  @@unique([mercadoId, userId])
  @@map("grupo_mercado_votos")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SocialPost {
  id              String   @id @default(cuid())
  date            String   // YYYY-MM-DD in Brasilia time
  marketTitle     String
  marketSlug      String
  probability     Int
  unsplashUrl     String
  unsplashAuthor  String?
  ogImageUrl      String
  caption         String   @db.Text
  instagramPostId String?
  twitterPostId   String?
  status          String   @default("pending") // pending, published, failed, ready
  error           String?
  createdAt       DateTime @default(now())
  platform      String   @default("instagram") // "instagram" | "twitter"
  scheduledTime String?                         // "08:00", "12:00", "17:00", "19:00", "21:00"
  imageFormat   String   @default("square")     // "square" | "landscape"

  @@map("social_posts")
}
